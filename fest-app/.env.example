# API base URL. Used when running the Expo web build against a remote
# backend. Native builds derive the host from Metro's scriptURL when unset.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api

# WebSocket base URL. Derived from EXPO_PUBLIC_API_BASE_URL when unset.
# EXPO_PUBLIC_WS_BASE_URL=ws://localhost:3001/api/ws

# Sentry DSN for the React Native / Expo app. When unset, Sentry is a
# no-op and the app still works normally.
# EXPO_PUBLIC_SENTRY_DSN=https://public@sentry.example.com/1
